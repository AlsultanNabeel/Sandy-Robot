# انسخ هذا الملف إلى .env واملأ القيم الفعلية

OPENAI_API_KEY=sk-your-key
GEMINI_API_KEY=
TELEGRAM_BOT_TOKEN=123456:ABCDEF
OPENAI_MODEL=gpt-4o
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# الشبكة
SANDY_IP=192.168.8.100
CAM_IP=192.168.8.150
SANDY_USER_CHAT_ID=123456789

# وضع التحكم الرسمي
# اللوحة الرئيسية ESP32 تعتمد Arduino Cloud
# الكاميرا تعتمد HTTP
SANDY_COMMAND_MODE=cloud

# لا نعتمد حالياً على شاشة HTTP القديمة
SANDY_ENABLE_SCREEN_HTTP=0

# حركة القاعدة غير مفعلة الآن
SANDY_ENABLE_BASE_MOTION=0

# Arduino Cloud credentials
ARDUINO_CLIENT_ID=YOUR_ARDUINO_CLIENT_ID
ARDUINO_CLIENT_SECRET=YOUR_ARDUINO_CLIENT_SECRET
ARDUINO_ORG_ID=YOUR_ARDUINO_ORG_ID
SANDY_DEVICE_ID=YOUR_SANDY_DEVICE_ID
CAMERA_DEVICE_ID=YOUR_CAMERA_DEVICE_ID
SANDY_THING_ID=YOUR_SANDY_THING_ID

# الصوت والاستماع
SANDY_TTS_VOICE=ar-LB-LaylaNeural
SANDY_TTS_RATE=+15%
LISTEN_TIMEOUT=5
LISTEN_PHRASE_LIMIT=12
USE_MIC=1

# camera auth defaults used by Python gateway
CAM_SNAPSHOT_TOKEN=
CAM_SECRET_PASSPHRASE=
CAM_HTTP_USER=YOUR_CAMERA_HTTP_USER
CAM_HTTP_PASS=
CAM_CONTROL_TOKEN=
CAM_SNAPSHOT_TOKEN=
CAM_FACES_DB=faces/faces_db.pkl
CAM_OWNER_NAMES=Owner
CAM_EYE_AUTO_CLOSE_SEC=20

# cloud brain gateway
SANDY_CLOUD_URL=
SANDY_CLOUD_FUNCTION_KEY=

# debug
SANDY_DEBUG=0
SANDY_FACE_MIN_INTERVAL_SEC=0.10